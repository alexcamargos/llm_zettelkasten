# Caches e artefatos Python.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest-tmp/
.tmp/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.ipynb_checkpoints/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Empacotamento, builds e distribuicao.
*.egg-info/
.eggs/
build/
dist/
wheels/
*.egg

# Arquivos especificos de Sistema Operacional (Windows, Linux, macOS)
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
.DS_Store
.AppleDouble
.LSOverride

# ==========================================
# Objetos especificos do projeto
# ==========================================

# Cache PageIndex: artefatos gerados localmente (arvore e manifest) nao entram no Git.
.pageindex/*
!.pageindex/.gitkeep

# Ambiente e segredos locais.
.env
.venv/
.venv-codex/
.uv-cache/

# Logs e estado gerado pelo motor Python.
logs/
.state/historico_ingestao.txt
.state/embeddings_index.json
